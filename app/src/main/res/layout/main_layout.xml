<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/AppBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="2"
    android:rowCount="2"
    android:padding="8dp"
    android:gravity="center"
    android:fitsSystemWindows="true">

    <!-- City -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/image1"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:contentDescription="@+id/name1"
            android:scaleType="centerCrop" />

        <TextView
            style="@style/GreenText"
            android:id="@+id/name1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/city" />

        <RatingBar
            android:id="@+id/rating1"
            style="?android:attr/ratingBarStyleIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:numStars="5"
            android:scaleX="0.5"
            android:scaleY="0.5"
            android:stepSize="0.5" />
    </LinearLayout>

    <!-- Fountain -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/image2"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:contentDescription="@+id/name2"
            android:scaleType="centerCrop"/>

        <TextView
            style="@style/GreenText"
            android:id="@+id/name2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/localfountain"/>

        <RatingBar
            style="?android:attr/ratingBarStyleIndicator"
            android:id="@+id/rating2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:gravity="center"
            android:scaleX="0.5"
            android:scaleY="0.5"/>
    </LinearLayout>

    <!-- Rural Town -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/image3"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:contentDescription="@+id/name3"
            android:scaleType="centerCrop"/>

        <TextView
            style="@style/GreenText"
            android:id="@+id/name3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ruraltown"/>

        <RatingBar
            style="?android:attr/ratingBarStyleIndicator"
            android:id="@+id/rating3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:gravity="center"
            android:scaleX="0.5"
            android:scaleY="0.5"/>
    </LinearLayout>

    <!-- Suburb -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/image4"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:contentDescription="@+id/name4"
            android:scaleType="centerCrop"/>

        <TextView
            style="@style/GreenText"
            android:id="@+id/name4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/suburbia"/>

        <RatingBar
            style="?android:attr/ratingBarStyleIndicator"
            android:id="@+id/rating4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:gravity="center"
            android:scaleX="0.5"
            android:scaleY="0.5"/>
    </LinearLayout>

</GridLayout>